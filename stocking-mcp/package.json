{
  "name": "stocking-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Family Grocery Tracker — runs as AWS Lambda or local stdio",
  "type": "module",
  "main": "dist/lambda.js",
  "exports": {
    ".": "./dist/lambda.js",
    "./stdio": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "package": "npm run build && zip -r ../mcp-lambda.zip dist node_modules package.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
