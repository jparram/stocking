# Amplify Gen 2 AppSync endpoint
# Found in: AWS Console → AppSync → your API → Settings → API URL
# Or: amplify_outputs.json after first deploy (key: API.GraphQL.endpoint)
APPSYNC_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql

# AppSync API key
# Found in: AWS Console → AppSync → your API → Settings → API keys
# Or: amplify_outputs.json (key: API.GraphQL.apiKey)
APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# First Sam's Sunday — used to calculate which store is due each week
# Format: YYYY-MM-DD
CADENCE_START_DATE=2026-01-04

# Kroger Developer API (for Harris Teeter product search)
# Register at: https://developer.kroger.com
# Use client_credentials grant; request product.compact scope
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# Harris Teeter store location ID — required for pricing data
# Find yours: GET https://api-ce.kroger.com/v1/locations?filter.zipCode.near=XXXXX
HT_LOCATION_ID=

# Bearer token for Lambda HTTP endpoint (optional — omit to disable auth check)
MCP_AUTH_TOKEN=
